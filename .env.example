# Chave usada apenas no backend para criptografar dados sensíveis.
# Nunca coloque esta chave no frontend.
# Gere uma chave real com:
# node -e "console.log('base64:' + require('node:crypto').randomBytes(32).toString('base64'))"
PSICOTAREFAS_SENSITIVE_DATA_KEY=base64:COLE_AQUI_UMA_CHAVE_DE_32_BYTES_EM_BASE64

# E-mail autorizado a acessar rotas administrativas do backend.
ADMIN_EMAIL=marcos@rubo.com.br
